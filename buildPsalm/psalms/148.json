[{"la":["Laud\u00e1te D\u00f3minum de c\u00e6lis:","laud\u00e1te eum in exc\u00e9lsis."],"fr":""},{"la":["Laud\u00e1te eum, omnes \u00c1ngeli eius:","laud\u00e1te eum, omnes virt\u00fates eius."],"fr":""},{"la":["Laud\u00e1te eum, sol et luna:","laud\u00e1te eum, omnes stell\u00e6 et lumen."],"fr":""},{"la":["Laud\u00e1te eum, c\u00e6li c\u00e6l\u00f3rum:","et aqu\u00e6 omnes, qu\u00e6 super c\u00e6los sunt, laudent nomen D\u00f3mini."],"fr":""},{"la":["Quia ipse dixit, et facta sunt:","ipse mand\u00e1vit, et cre\u00e1ta sunt."],"fr":""},{"la":["St\u00e1tuit ea in \u00e6t\u00e9rnum, et in s\u01fdculum s\u01fdculi:","pr\u00e6c\u00e9ptum p\u00f3suit, et non pr\u00e6ter\u00edbit."],"fr":""},{"la":["Laud\u00e1te D\u00f3minum de terra,","drac\u00f3nes, et omnes ab\u00fdssi."],"fr":""},{"la":["Ignis, grando, nix, gl\u00e1cies, sp\u00edritus procell\u00e1rum:","qu\u00e6 f\u00e1ciunt verbum eius:"],"fr":""},{"la":["Montes, et omnes colles:","ligna fruct\u00edfera, et omnes cedri."],"fr":""},{"la":["B\u00e9sti\u00e6, et univ\u00e9rsa p\u00e9cora:","serp\u00e9ntes, et v\u00f3lucres penn\u00e1t\u00e6:"],"fr":""},{"la":["Reges terr\u00e6, et omnes p\u00f3puli:","pr\u00edncipes, et omnes i\u00fadices terr\u00e6."],"fr":""},{"la":["I\u00favenes, et v\u00edrgines: senes cum iuni\u00f3ribus laudent nomen D\u00f3mini:","quia exalt\u00e1tum est nomen eius sol\u00edus."],"fr":""},{"la":["Conf\u00e9ssio eius super c\u00e6lum et terram:","et exalt\u00e1vit cornu p\u00f3puli sui."],"fr":""},{"la":["Hymnus \u00f3mnibus sanctis eius:","f\u00edliis Isra\u00ebl, p\u00f3pulo appropinqu\u00e1nti sibi."],"fr":""}]